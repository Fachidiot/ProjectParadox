  m_Script: {fileID: 11500000, guid: 9f7cf940fd7994b429c380562ecc3fc9, type: 3}
  m_Name: Table_Tutorial
  m_EditorClassIdentifier:
  m_Entries:
  - id: Tutorial_Sword
    nameKor: "아레스의 검"
    nameEng: "Sword of Ares"
    nameJap: "アレスの剣"
    explainKor: "마우스 왼쪽 버튼을 눌러\r\r\n공격 할 수 있습니다."
    explainEng: "Press the left mouse button\r\r\nto attack."
    explainJap: "マウスの左ボタンを押して\r\r\n攻撃できます。"
  - id: Tutorial_Shoes
    nameKor: "헤르메스의 탈라리아"
    nameEng: "Talaria of Hermes"
    nameJap: "ヘルメスのタラリア"
    explainKor: "스페이스 버튼을 두번 눌러\r\r\n이단점프가 가능합니다."
    explainEng: "Press the space bar twice\r\r\nto double jump."
    explainJap: "スペースキーを2回押して\r\r\n二段ジャンプができます。"
  - id: Tutorial_Wing
    nameKor: "이카루스의 날개"
    nameEng: "Wings of Icarus"
    nameJap: "イカロスの翼"
    explainKor: "더블점프 상태에서 스페이스를 눌러\r\r\n날 수 있습니다."
    explainEng: "Press space while double jumping\r\r\nto fly."
    explainJap: "二段ジャンプ中にスペースを押して\r\r\n飛ぶことができます。"
